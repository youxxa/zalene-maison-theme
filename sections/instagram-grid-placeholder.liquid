{% comment %}
  filename: sections/instagram-grid-placeholder.liquid
  purpose: Editable six-image editorial grid for Instagram or UGC placeholders on the homepage.
  key variables: section.blocks, block.settings.image, block.settings.link
  ai_agent_edit_guide: Edit the placeholder grid structure or media density here. Keep grid styling in CSS and update imagery through section blocks.
{% endcomment %}
{% if section.settings.show_section %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      {% render 'section-intro',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      %}
      <div class="instagram-grid">
        {% for block in section.blocks %}
          <a class="instagram-grid__media" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {% render 'responsive-image',
                image: block.settings.image,
                class: 'instagram-grid__image',
                alt: section.settings.heading,
                sizes: '(min-width: 750px) 32vw, 48vw',
                width: 720
              %}
            {% else %}
              <div class="empty-state">[REPLACE WITH PHOTO]</div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Instagram grid",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "A Glimpse in Motion" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "A curated grid for editorial and community imagery." },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-light",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-dark",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "ugc_image",
      "name": "Grid image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram grid",
      "blocks": [
        { "type": "ugc_image" },
        { "type": "ugc_image" },
        { "type": "ugc_image" },
        { "type": "ugc_image" },
        { "type": "ugc_image" },
        { "type": "ugc_image" }
      ]
    }
  ]
}
{% endschema %}
