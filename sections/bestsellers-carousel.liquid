{% comment %}
  filename: sections/bestsellers-carousel.liquid
  purpose: Bestsellers carousel that supports swipe gestures on mobile and card-based browsing on larger screens.
  key variables: section.settings.collection, collection.products
  ai_agent_edit_guide: Edit carousel source or merchandising density here. Keep card structure inside the product-card snippet and swipe logic in theme.js.
{% endcomment %}
{% if section.settings.show_section %}
  {% assign featured_collection = section.settings.collection %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      {% render 'section-intro',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      %}
      <div class="carousel" data-carousel>
        <div class="carousel__controls">
          <button class="icon-button" type="button" data-carousel-prev aria-label="{{ 'accessibility.previous_slide' | t }}">
            {% render 'icon-chevron', class: 'is-rotated' %}
          </button>
          <button class="icon-button" type="button" data-carousel-next aria-label="{{ 'accessibility.next_slide' | t }}">
            {% render 'icon-chevron', class: 'is-rotated-negative' %}
          </button>
        </div>
        <div class="carousel__viewport" data-carousel-viewport>
          {% for product in featured_collection.products limit: section.settings.products_to_show %}
            <div class="carousel__slide" data-carousel-slide>
              {% render 'product-card', product: product, show_quick_add: true %}
            </div>
          {% else %}
            <div class="empty-state">{{ 'general.empty' | t }}</div>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Bestsellers carousel",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Bestsellers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "Signature pieces chosen again and again." },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 8 },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-dark",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-light",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ],
  "presets": [
    { "name": "Bestsellers carousel" }
  ]
}
{% endschema %}
