<style>
  .brand-story {
    position: relative;
    width: 100%;
    background-color: var(--color-background-mid);
    color: var(--color-text-primary);
    overflow: hidden;
  }
  .brand-story__inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin: 0 auto;
    max-width: var(--container-width);
  }
  @media screen and (min-width: 768px) {
    .brand-story__inner {
      flex-direction: row;
      align-items: center;
      min-height: 80vh;
    }
  }
  .brand-story__media {
    flex: 0 0 100%;
    position: relative;
    min-height: 50vh;
  }
  @media screen and (min-width: 768px) {
    .brand-story__media {
      flex: 0 0 60%;
      min-height: auto;
      height: 100%;
      padding-right: var(--space-4);
    }
  }
  .brand-story__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .brand-story__content-wrapper {
    flex: 0 0 100%;
    padding: var(--space-4) var(--space-2);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media screen and (min-width: 768px) {
    .brand-story__content-wrapper {
      flex: 0 0 40%;
      padding: var(--space-6) var(--space-4) var(--space-6) 0;
    }
  }
  .brand-story__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-size: 35vw;
    font-style: italic;
    color: var(--color-gold-overlay);
    opacity: 0.05;
    z-index: 0;
    pointer-events: none;
    line-height: 1;
  }
  @media screen and (min-width: 768px) {
    .brand-story__watermark {
      font-size: 25vw;
    }
  }
  .brand-story__content {
    position: relative;
    z-index: 1;
    max-width: var(--copy-max-width);
  }
  .brand-story__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    margin: 0 0 var(--space-3) 0;
    line-height: 1.1;
  }
  .brand-story__divider {
    width: 60px;
    height: 0.75px;
    background-color: var(--color-primary-accent);
    margin-bottom: var(--space-3);
  }
  .brand-story__text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-primary);
  }
</style>

<div class="brand-story">
  <div class="brand-story__inner fade-in-on-scroll">
    <div class="brand-story__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 60vw, 100vw', widths: '375, 550, 750, 1100, 1500, 2000' }}
      {% else %}
        <div style="background-color: #f0f0f0; width: 100%; height: 100%; min-height: 50vh;"></div>
      {% endif %}
    </div>

    <div class="brand-story__content-wrapper">
      <div class="brand-story__watermark">Z</div>
      <div class="brand-story__content">
        <h2 class="brand-story__title">{{ section.settings.heading | default: 'Our Philosophy' }}</h2>
        <div class="brand-story__divider"></div>
        <div class="brand-story__text">
          {{ section.settings.text | default: '<p>A dedication to quiet luxury, bridging the elegance of French fashion with Arabic minimalism. Every piece is curated to tell a story of unspoken confidence.</p>' }}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Philosophy"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Story Text",
      "default": "<p>Zalène Maison represents the apex of minimalist design.</p>"
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "category": "Editorial"
    }
  ]
}
{% endschema %}
