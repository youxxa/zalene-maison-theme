{% comment %}
  filename: sections/brand-story.liquid
  purpose: Editorial brand story split section with image, watermark accent, and restrained typography.
  key variables: section.settings.image, section.settings.heading, section.settings.text
  ai_agent_edit_guide: Edit structure here. Keep styling in assets/base.css. Keep copy in section settings/locales.
{% endcomment %}

<section class="brand-story scheme-mid text-dark section-shell">
  <div class="brand-story__inner" data-reveal>
    <div class="brand-story__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 60vw, 100vw', widths: '375, 550, 750, 1100, 1500, 2000' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
      {% endif %}
    </div>

    <div class="brand-story__content-wrapper">
      <div class="brand-story__watermark" aria-hidden="true">Z</div>
      <div class="brand-story__content">
        <h2 class="brand-story__title">{{ section.settings.heading }}</h2>
        <div class="brand-story__divider" aria-hidden="true"></div>
        <div class="brand-story__text rich-copy">
          {{ section.settings.text }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Editorial image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Philosophy" },
    { "type": "richtext", "id": "text", "label": "Story text", "default": "<p>Zalène Maison is built around precision, restraint, and beauty that unfolds in texture rather than noise.</p>" }
  ],
  "presets": [
    { "name": "Brand story", "category": "Editorial" }
  ]
}
{% endschema %}

