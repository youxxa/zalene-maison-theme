{% comment %}
  filename: sections/related-products.liquid
  purpose: Related products section based on the current product's first collection for a stable, editable recommendation context.
  key variables: product.collections.first.products, section.settings.products_to_show
  ai_agent_edit_guide: Edit recommendation sourcing or presentation here. Keep shared product markup in the product-card snippet.
{% endcomment %}
{% if section.settings.show_section and product.collections.first != blank %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      {% render 'section-intro',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      %}
      <div class="product-grid">
        {% assign related_count = 0 %}
        {% for related_product in product.collections.first.products %}
          {% if related_product.id != product.id %}
            <div class="product-grid__item">
              {% render 'product-card', product: related_product, show_quick_add: true %}
            </div>
            {% assign related_count = related_count | plus: 1 %}
          {% endif %}
          {% if related_count >= section.settings.products_to_show %}
            {% break %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "You May Also Appreciate" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "A continuation of the edit." },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-light",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-dark",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-md",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-xl",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ]
}
{% endschema %}
