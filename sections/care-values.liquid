{% comment %}
  filename: sections/care-values.liquid
  purpose: Value pillars section highlighting craftsmanship, longevity, and care in a bordered luxury presentation.
  key variables: section.blocks, block.settings.heading, block.settings.body
  ai_agent_edit_guide: Edit the number of pillars, icon treatment, or copy structure here. Keep visual rhythm in CSS.
{% endcomment %}
{% if section.settings.show_section %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      {% render 'section-intro',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      %}
      <div class="values-grid">
        {% for block in section.blocks %}
          <article class="values-grid__item" {{ block.shopify_attributes }}>
            <span class="values-grid__icon" aria-hidden="true"></span>
            <h3 class="product-card__title">{{ block.settings.heading }}</h3>
            <p>{{ block.settings.body }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Care and values",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Care and Values" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "Luxury is preserved through intention." },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-dark",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-light",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading text", "default": "Craftsmanship" },
        { "type": "textarea", "id": "body", "label": "Body copy", "default": "Each garment is refined through thoughtful tailoring, premium textiles, and quiet finishing details." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Care and values",
      "blocks": [
        { "type": "pillar" },
        { "type": "pillar", "settings": { "heading": "Longevity", "body": "Designed to transcend a single season, each piece is made to remain relevant and wearable over time." } },
        { "type": "pillar", "settings": { "heading": "Considered Service", "body": "From packaging to delivery, every touchpoint is shaped to feel calm, clear, and elevated." } }
      ]
    }
  ]
}
{% endschema %}
