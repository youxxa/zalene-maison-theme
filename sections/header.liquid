{% comment %}
  filename: sections/header.liquid
  purpose: Sticky site header with brand mark, desktop mega menu support, mobile full-screen navigation drawer, predictive search, and cart trigger.
  key variables: section.settings.desktop_menu, section.settings.mobile_menu, cart.item_count, link.links
  ai_agent_edit_guide: Edit navigation structure, utility controls, or drawer composition here. Keep brand rendering in the brand-logo snippet and global behavior in theme.js.
{% endcomment %}
<header class="site-header scheme-{{ section.settings.scheme_style }} text-{{ section.settings.text_style }}" data-section-id="header">
  <div class="site-header__inner">
    <div class="site-header__brand">
      <a href="{{ routes.root_url }}" aria-label="{{ settings.brand_display_name }}">
        {% render 'brand-logo', inverted: section.settings.scheme_style == 'dark' %}
      </a>
    </div>

    <nav class="site-header__nav" aria-label="{{ 'header.menu' | t }}">
      <ul class="mega-menu" role="list">
        {% for link in section.settings.desktop_menu.links %}
          <li class="mega-menu__item">
            <a class="mega-menu__link" href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
            {% if link.links != blank %}
              <div class="mega-menu__panel">
                {% for child_link in link.links %}
                  <div class="footer-nav">
                    <a class="text-link" href="{{ child_link.url }}">{{ child_link.title }}</a>
                    {% if child_link.links != blank %}
                      {% for grandchild_link in child_link.links %}
                        <a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a>
                      {% endfor %}
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__utilities">
      <!-- 1. Bag (Cart) -->
      <button class="icon-button" type="button" data-drawer-target="CartDrawer" aria-label="{{ 'accessibility.open_cart' | t }}">
        <span class="visually-hidden">{{ 'header.cart' | t }}</span>
        {% render 'icon-cart' %}
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>

      <!-- 2. Search -->
      <button class="icon-button" type="button" data-drawer-target="SearchDrawer" aria-label="{{ 'accessibility.open_search' | t }}">
        {% render 'icon-search' %}
      </button>

      <!-- 3. Account (User) -->
      <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="icon-button" aria-label="{{ 'accessibility.account' | t }}">
        {% render 'icon-account' %}
      </a>

      <!-- 4. Menu -->
      <button class="icon-button menu-toggle-btn" type="button" data-drawer-target="MobileMenuDrawer" aria-label="{{ 'accessibility.open_menu' | t }}">
        {% render 'icon-menu' %}
        <span class="menu-label small-hide">MENU</span>
      </button>
    </div>
  </div>

  <div id="MobileMenuDrawer" class="drawer" aria-hidden="true">
    <div class="drawer__overlay" data-drawer-overlay></div>
    <div class="drawer__panel drawer__panel--fullscreen scheme-dark text-light" data-drawer-panel>
      <div class="drawer__header">
        <p class="section-intro__eyebrow">{{ settings.brand_display_name }}</p>
        <button class="icon-button" type="button" data-drawer-close="MobileMenuDrawer" aria-label="{{ 'accessibility.close_menu' | t }}">
          {% render 'icon-close' %}
        </button>
      </div>
      <div class="drawer__body">
        <nav class="drawer-nav" aria-label="{{ 'header.menu' | t }}">
          {% for link in section.settings.mobile_menu.links %}
            <div>
              <a class="drawer-nav__link" href="{{ link.url }}">
                <span>{{ link.title }}</span>
                {% if link.links != blank %}
                  {% render 'icon-chevron' %}
                {% endif %}
              </a>
              {% if link.links != blank %}
                <div class="drawer-nav__child-list">
                  {% for child_link in link.links %}
                    <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </nav>
      </div>
      <div class="drawer__footer">
        {% render 'social-links' %}
      </div>
    </div>
  </div>

  <div id="SearchDrawer" class="drawer" aria-hidden="true">
    <div class="drawer__overlay" data-drawer-overlay></div>
    <div class="drawer__panel drawer__panel--left scheme-light text-dark" data-drawer-panel>
      <div class="drawer__header">
        <h2 class="drawer__title">{{ 'header.search' | t }}</h2>
        <button class="icon-button" type="button" data-drawer-close="SearchDrawer" aria-label="{{ 'accessibility.close_search' | t }}">
          {% render 'icon-close' %}
        </button>
      </div>
      <form class="search-form" action="{{ routes.search_url }}" method="get" role="search" data-predictive-search-form>
        <input
          class="search-form__field"
          type="search"
          name="q"
          value=""
          placeholder="{{ 'accessibility.search' | t }}"
          aria-label="{{ 'header.search' | t }}"
        >
        <div class="predictive-search__results" data-predictive-results></div>
      </form>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "desktop_menu",
      "label": "Desktop menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "scheme_style",
      "label": "Background scheme",
      "default": "light",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ]
    },
    {
      "type": "select",
      "id": "text_style",
      "label": "Text scheme",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark text" },
        { "value": "light", "label": "Light text" }
      ]
    }
  ]
}
{% endschema %}
