{% comment %}
  filename: sections/newsletter-signup-strip.liquid
  purpose: Homepage newsletter capture strip with refined copy, gold-bordered email field, and customer form integration.
  key variables: section.settings.heading, section.settings.subheading, customer form
  ai_agent_edit_guide: Edit signup layout or supporting copy here. Keep customer form processing delegated to Shopify.
{% endcomment %}
{% if section.settings.show_section %}
  {% assign newsletter_button_label = section.settings.button_label %}
  {% if newsletter_button_label == blank %}
    {% assign newsletter_button_label = 'general.subscribe' | t %}
  {% endif %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      <div class="newsletter-strip__layout">
        {% render 'section-intro',
          eyebrow: section.settings.eyebrow,
          heading: section.settings.heading,
          subheading: section.settings.subheading
        %}
        {% form 'customer', class: 'newsletter-strip__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ 'general.email' | t }}</label>
          <input
            class="form-field"
            id="NewsletterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            placeholder="{{ 'newsletter.placeholder' | t }}"
            required
          >
          <button class="button button--primary" type="submit">{{ newsletter_button_label }}</button>
        {% endform %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Newsletter signup strip",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Stay Connected" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "Stay connected. Discover new collections first." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "video", "id": "video", "label": "Video" },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-dark",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-light",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ],
  "presets": [
    { "name": "Newsletter signup strip" }
  ]
}
{% endschema %}
