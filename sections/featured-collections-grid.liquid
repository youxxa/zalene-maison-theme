{% comment %}
  filename: sections/featured-collections-grid.liquid
  purpose: Homepage editorial collection grid with alternating light and dark cards, collection imagery, and luxury spacing.
  key variables: section.blocks, block.settings.collection, block.settings.card_tone
  ai_agent_edit_guide: Edit collection card composition or merchandising rules here. Keep repeated card styling in global CSS.
{% endcomment %}
{% if section.settings.show_section %}
  {% assign default_collection_button = 'general.shop_now' | t %}
  <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
    <div class="page-width">
      {% render 'section-intro',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      %}
      <div class="collection-cards">
        {% for block in section.blocks %}
          {% assign collection_object = block.settings.collection %}
          <article class="collection-cards__item collection-cards__item--{{ block.settings.card_tone }}" {{ block.shopify_attributes }}>
            <a class="collection-cards__media" href="{{ collection_object.url | default: block.settings.button_url }}">
              {% if block.settings.image != blank %}
                {% render 'responsive-image',
                  image: block.settings.image,
                  class: 'collection-cards__image',
                  alt: collection_object.title,
                  sizes: '(min-width: 990px) 30vw, 90vw',
                  width: 900
                %}
              {% elsif collection_object.featured_image != blank %}
                {% render 'responsive-image',
                  image: collection_object.featured_image,
                  class: 'collection-cards__image',
                  alt: collection_object.title,
                  sizes: '(min-width: 990px) 30vw, 90vw',
                  width: 900
                %}
              {% endif %}
            </a>
            <div class="product-card__content">
              <p class="product-card__title">
                <a href="{{ collection_object.url | default: block.settings.button_url }}">{{ block.settings.heading | default: collection_object.title }}</a>
              </p>
              <p>{{ block.settings.subheading }}</p>
              <a class="text-link" href="{{ collection_object.url | default: block.settings.button_url }}">{{ block.settings.button_label | default: default_collection_button }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Featured collections grid",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Featured Collections" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "A measured edit of signature silhouettes." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the edit" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-light",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-dark",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading text" },
        { "type": "textarea", "id": "subheading", "label": "Subheading text" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_url", "label": "Button URL" },
        {
          "type": "select",
          "id": "card_tone",
          "label": "Card tone",
          "default": "light",
          "options": [
            { "value": "light", "label": "Light" },
            { "value": "dark", "label": "Dark" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections grid",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
