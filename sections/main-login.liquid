{% comment %}
  filename: sections/main-login.liquid
  purpose: Ultra-minimalist login portal integrating guest checkout blocks and registration incentives.
{% endcomment %}
<section class="auth section-shell scheme-light text-dark">
  <div class="page-width">
  <div class="auth__container">
    <h1 class="auth__title">{{ 'account.login_heading' | t }}</h1>

    {% form 'customer_login', novalidate: 'novalidate' %}
      {%- if form.errors -%}
        <div class="auth__errors">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="auth__field">
        <label class="auth__label" for="CustomerEmail">{{ 'account.email_label' | t }}</label>
        <input class="form-field" type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" required>
      </div>

      {%- if form.password_needed -%}
        <div class="auth__field">
          <label class="auth__label" for="CustomerPassword">{{ 'account.password_label' | t }}</label>
          <input class="form-field" type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" required>
        </div>
      {%- endif -%}

      <button type="submit" class="button button--outline button--full">{{ 'account.sign_in' | t }}</button>

      <div class="auth__footer">
        <p>{{ 'account.new_to_maison' | t }} <a class="auth__link" href="{{ routes.account_register_url }}">{{ 'account.create_account' | t }}</a></p>
      </div>
    {% endform %}

    {%- if shop.checkout.guest_login -%}
      <div class="auth__guest">
        <h2 class="auth__subtitle">{{ 'account.guest_checkout' | t }}</h2>
        {% form 'guest_login' %}
          <button type="submit" class="button button--outline button--full">{{ 'account.continue_to_checkout' | t }}</button>
        {% endform %}
      </div>
    {%- endif -%}
    
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Login",
  "settings": []
}
{% endschema %}
