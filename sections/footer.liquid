{% comment %}
  filename: sections/footer.liquid
  purpose: Quiet luxury footer with a single navigation axis and centered copyright line.
  key variables: section.settings.collections_url, section.settings.journal_url, section.settings.legal_url, section.settings.contact_url
  ai_agent_edit_guide: Keep the DOM flat and centered here. Edit quiet-luxury footer styling in assets/base.css and footer destinations in schema settings.
{% endcomment %}
{% assign collections_url = section.settings.collections_url | default: routes.all_products_collection_url %}
{% assign journal_url = section.settings.journal_url | default: '/blogs/news' %}
{% assign legal_url = section.settings.legal_url | default: '/policies/privacy-policy' %}
{% assign contact_url = section.settings.contact_url | default: '/pages/contact' %}

<footer class="site-footer" role="contentinfo">
  <nav class="site-footer__nav" aria-label="Footer">
    <a class="site-footer__link" href="{{ collections_url }}">COLLECTIONS</a>
    <a class="site-footer__link" href="{{ journal_url }}">JOURNAL</a>
    <a class="site-footer__link" href="{{ legal_url }}">LEGAL</a>
    <a class="site-footer__link" href="{{ contact_url }}">CONTACT</a>
  </nav>
  <p class="site-footer__copyright">© 2026 ZALÈNE MAISON.</p>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "url",
      "id": "collections_url",
      "label": "Collections link"
    },
    {
      "type": "url",
      "id": "journal_url",
      "label": "Journal link"
    },
    {
      "type": "url",
      "id": "legal_url",
      "label": "Legal link"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact link"
    }
  ]
}
{% endschema %}
