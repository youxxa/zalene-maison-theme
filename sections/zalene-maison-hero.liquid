      "type": "text",
      "id": "strip_item_3_label",
      "label": "Strip item 3 — text",
      "default": "Secure checkout"
    }

  ],
  "presets": [
    {
      "name": "ZM — Brand Hero",
      "category": "Zalène Maison"
    }
  ]
}
{% endschema %}
