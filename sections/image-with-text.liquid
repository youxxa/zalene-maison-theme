{% comment %}
  filename: sections/image-with-text.liquid
  purpose: A flexible "Canva-style" draggable block combining an image and text content, ideal for editorial layouts.
{% endcomment %}

<section class="section-shell scheme-{{ section.settings.bg_color }} text-{{ section.settings.text_color }} section-spacing--top-space-{{ section.settings.padding_top }} section-spacing--bottom-space-{{ section.settings.padding_bottom }}">
  <div class="page-width">
    <div class="image-text-section {% if section.settings.layout == 'right' %}image-text-section--image-right{% endif %}">
      <div class="image-text-section__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
        {%- endif -%}
      </div>
      <div class="image-text-section__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'eyebrow' -%}
              <p class="section-intro__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- when 'heading' -%}
              <h2 class="section-intro__heading image-text-section__heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
            {%- when 'text' -%}
              <div class="image-text-section__text rich-copy" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
            {%- when 'button' -%}
              <div {{ block.shopify_attributes }}>
                <a href="{{ block.settings.button_link }}" class="button button--{{ block.settings.button_style }}">
                  {{ block.settings.button_label }}
                </a>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image placement on desktop",
      "options": [
        { "value": "left", "label": "Image on left" },
        { "value": "right", "label": "Image on right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "mid", "label": "Mid" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "light"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top spacing",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "lg"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow text",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "default": "Story" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "default": "Image with text" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        { "type": "richtext", "id": "text", "default": "<p>Combine imagery and text to showcase your brand.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label", "default": "Read more" },
        { "type": "url", "id": "button_link" },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
