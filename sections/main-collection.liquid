{% comment %}
  filename: sections/main-collection.liquid
  purpose: Main collection template with filter groups, sort controls, mobile filter drawer, and progressive product loading.
  key variables: collection, collection.filters, collection.products, section.settings.pagination_mode
  ai_agent_edit_guide: Edit filter layout, sorting controls, or grid behavior here. Keep product cards in the shared product-card snippet and pagination behavior in theme.js.
{% endcomment %}
{% if section.settings.show_section %}
  {% assign load_more_label = section.settings.button_label %}
  {% if load_more_label == blank %}
    {% assign load_more_label = 'collection.load_more' | t %}
  {% endif %}
  {% paginate collection.products by section.settings.products_per_page %}
    {% capture collection_filters_markup %}
      {% if collection.filters != blank %}
        <form action="{{ collection.url }}" method="get" class="filter-groups">
          {% for filter in collection.filters %}
            <div class="filter-group" data-accordion>
              <button class="accordion__button" type="button" data-accordion-button aria-expanded="false">
                <span>{{ filter.label }}</span>
                {% render 'icon-chevron' %}
              </button>
              <div class="accordion__panel">
                {% case filter.type %}
                  {% when 'price_range' %}
                    <div class="search-form">
                      <label for="Filter-{{ filter.label | escape }}-min">{{ filter.min_value.value | default: 0 | money_without_currency }}</label>
                      <input class="form-field" id="Filter-{{ filter.label | escape }}-min" name="{{ filter.min_value.param_name }}" type="number" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                      <label for="Filter-{{ filter.label | escape }}-max">{{ filter.max_value.value | default: filter.range_max | money_without_currency }}</label>
                      <input class="form-field" id="Filter-{{ filter.label | escape }}-max" name="{{ filter.max_value.param_name }}" type="number" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
                    </div>
                  {% else %}
                    {% for value in filter.values %}
                      <label class="drawer-nav__link" for="Filter-{{ filter.label | handle }}-{{ forloop.index }}">
                        <span>{{ value.label }} ({{ value.count }})</span>
                        <input
                          id="Filter-{{ filter.label | handle }}-{{ forloop.index }}"
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        >
                      </label>
                    {% endfor %}
                  {% endcase %}
              </div>
            </div>
          {% endfor %}
          <button class="button button--secondary" type="submit">{{ 'general.apply' | t }}</button>
        </form>
      {% endif %}
    {% endcapture %}

    <section class="section-shell {{ section.settings.background_scheme }} {{ section.settings.text_scheme }} section-spacing--top-{{ section.settings.padding_top }} section-spacing--bottom-{{ section.settings.padding_bottom }}">
      <div class="page-width">
        {% render 'section-intro',
          eyebrow: section.settings.eyebrow,
          heading: collection.title | default: section.settings.heading,
          subheading: collection.description | strip_html | truncate: 140 | default: section.settings.subheading
        %}
        <div class="collection-toolbar">
          <span class="collection-toolbar__count">{{ 'collection.results' | t: count: collection.products_count }}</span>
          <div class="collection-toolbar__controls">
            <button class="collection-toolbar__refine-btn small-hide medium-hide" type="button" data-drawer-target="CollectionFiltersDrawer">{{ 'collection.filter_title' | t }}</button>
            <form action="{{ collection.url }}" method="get" class="collection-toolbar__sort-form">
              <label class="visually-hidden" for="CollectionSort">{{ 'collection.sort_label' | t }}</label>
              <select class="collection-toolbar__sort-select" id="CollectionSort" name="sort_by" onchange="this.form.submit()">
                {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}
                {% for option in collection.sort_options %}
                  <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>{{ option.name }}</option>
                {% endfor %}
              </select>
            </form>
          </div>
        </div>

        <div class="collection-layout">
          <aside class="collection-layout__sidebar small-hide medium-hide">
            {{ collection_filters_markup }}
          </aside>

          <div class="collection-layout__main" data-collection-pagination="{{ section.settings.pagination_mode }}">
            <div class="product-grid">
              {% for product in collection.products %}
                <div class="product-grid__item{% if forloop.index > 6 %} is-hidden{% endif %}" data-product-grid-item>
                  {% render 'product-card', product: product, show_quick_add: true %}
                </div>
              {% else %}
                <div class="empty-state">{{ 'collection.empty' | t }}</div>
              {% endfor %}
            </div>

            {% if collection.products.size > 6 %}
              <button class="button button--secondary" type="button" data-load-more>
                {{ load_more_label }}
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

    <div id="CollectionFiltersDrawer" class="drawer" aria-hidden="true">
      <div class="drawer__overlay" data-drawer-overlay></div>
      <div class="drawer__panel drawer__panel--left scheme-light text-dark" data-drawer-panel>
        <div class="drawer__header">
          <h2 class="drawer__title">{{ 'collection.filter_title' | t }}</h2>
          <button class="icon-button" type="button" data-drawer-close="CollectionFiltersDrawer" aria-label="{{ 'accessibility.close_filters' | t }}">
            {% render 'icon-close' %}
          </button>
        </div>
        <div class="drawer__body">
          {{ collection_filters_markup }}
        </div>
      </div>
    </div>
  {% endpaginate %}
{% endif %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elegance Redefined" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "Collection" },
    { "type": "textarea", "id": "subheading", "label": "Subheading text", "default": "A measured view of every silhouette." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Load more" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "select",
      "id": "pagination_mode",
      "label": "Pagination mode",
      "default": "load-more",
      "options": [
        { "value": "load-more", "label": "Load more" },
        { "value": "infinite-scroll", "label": "Infinite scroll" }
      ]
    },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 12, "max": 36, "step": 4, "default": 24 },
    {
      "type": "select",
      "id": "background_scheme",
      "label": "Background color",
      "default": "scheme-light",
      "options": [
        { "value": "scheme-light", "label": "Light" },
        { "value": "scheme-dark", "label": "Dark" },
        { "value": "scheme-mid", "label": "Mid" }
      ]
    },
    {
      "type": "select",
      "id": "text_scheme",
      "label": "Text color",
      "default": "text-dark",
      "options": [
        { "value": "text-dark", "label": "Dark text" },
        { "value": "text-light", "label": "Light text" }
      ]
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Padding top",
      "default": "space-lg",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": "space-xl",
      "options": [
        { "value": "space-sm", "label": "Small" },
        { "value": "space-md", "label": "Medium" },
        { "value": "space-lg", "label": "Large" },
        { "value": "space-xl", "label": "Extra large" }
      ]
    }
  ]
}
{% endschema %}
