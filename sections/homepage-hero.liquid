<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: flex-end; /* Bottom-left alignment by default */
    overflow: hidden;
  }
  .hero--centered {
    align-items: center;
    justify-content: center;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: var(--color-background-dark);
  }
  .hero__media img,
  .hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.8; /* Subtle darkening for text readability */
  }
  .hero__content {
    position: relative;
    z-index: 2;
    padding: var(--space-4) var(--space-2);
    width: 100%;
    max-width: var(--container-width);
    margin: 0 auto;
    color: var(--color-primary-light);
  }
  .hero--centered .hero__content {
    text-align: center;
    padding: var(--space-5) var(--space-3);
  }
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.1;
    margin: 0 0 var(--space-2) 0;
    font-weight: 400;
  }
  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.5rem;
    text-transform: uppercase;
    margin: 0 0 var(--space-3) 0;
  }
  .ghost-button-gold--hover-wash {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 44px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-primary-accent);
    border: 0.75px solid var(--color-primary-accent);
    background: transparent;
    transition: background-color var(--transition-medium), color var(--transition-medium);
  }
  .ghost-button-gold--hover-wash:hover {
    background-color: var(--color-gold-overlay);
    color: var(--color-primary-light);
  }
</style>

<div class="hero {% if section.settings.alignment == 'center' %}hero--centered{% endif %}">
  <div class="hero__media">
    {% if section.settings.video_url != blank %}
      <video autoplay loop muted playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 3000 | image_tag: loading: 'eager', sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000' }}
    {% endif %}
  </div>

  <div class="hero__content fade-in-on-scroll">
    {% if section.settings.title != blank %}
      <h1 class="hero__title">{{ section.settings.title }}</h1>
    {% endif %}
    
    {% if section.settings.subtitle != blank %}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="ghost-button-gold--hover-wash">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Homepage Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Paste a direct link to an MP4. Overrides image if set."
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "bottom_left", "label": "Bottom Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "bottom_left"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "L'Art de Vivre"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "A new collection of quiet luxury."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero",
      "category": "Curated Collections"
    }
  ]
}
{% endschema %}
