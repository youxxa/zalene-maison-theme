{% comment %}
  filename: sections/hero-banner.liquid
  purpose: A flexible "Canva-style" draggable block for edge-to-edge visual impact.
{% endcomment %}

<section class="hero-section {% if section.settings.height == 'full' %}hero-section--full-screen{% endif %} hero-section--overlay-{{ section.settings.overlay_opacity }}">
  <div class="hero-section__background">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
    {%- endif -%}
  </div>

  <div class="hero-section__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'eyebrow' -%}
          <p class="section-intro__eyebrow section-intro__eyebrow--inherit" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {%- when 'heading' -%}
          <h2 class="section-intro__heading hero-section__heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
        {%- when 'text' -%}
          <div class="hero-section__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
        {%- when 'button' -%}
          <div {{ block.shopify_attributes }}>
            <a href="{{ block.settings.button_link }}" class="button button--outline button--inherit">
              {{ block.settings.button_label }}
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 30
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "adapt", "label": "Adapt to screen" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "full"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow text",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "default": "New Collection" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "default": "Visual Impact" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "default": "<p>Introduce your new arrivals or campaign conceptually.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label", "default": "Explore" },
        { "type": "url", "id": "button_link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
