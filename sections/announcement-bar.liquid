{% comment %}
  filename: sections/announcement-bar.liquid
  purpose: Global announcement bar controlled by theme settings for shipping, launches, or service notices.
  key variables: settings.announcement_enabled, settings.announcement_text, settings.announcement_link
  ai_agent_edit_guide: Edit announcement structure or interaction here. Keep copy and colors managed through theme settings.
{% endcomment %}
{% if settings.announcement_enabled %}
  <section class="section-shell announcement-bar" aria-label="{{ 'announcement.default_text' | t }}">
    <div class="page-width">
      {% assign announcement_text = settings.announcement_text %}
      {% if announcement_text == blank %}
        {% assign announcement_text = 'announcement.default_text' | t %}
      {% endif %}
      {% if settings.announcement_link != blank %}
        <a class="announcement-bar__text" href="{{ settings.announcement_link }}">{{ announcement_text }}</a>
      {% else %}
        <p class="announcement-bar__text">{{ announcement_text }}</p>
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": []
}
{% endschema %}
