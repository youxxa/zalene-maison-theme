{% comment %}
  filename: sections/main-404.liquid
  purpose: Not-found template with French-Arabic minimalist negative space, refined serif headline, and a gold-outline return CTA.
  key variables: settings.brand_display_name, routes.root_url
  ai_agent_edit_guide: Edit layout structure here only. Keep typography, spacing, and button styling in assets/base.css and copy in locales/en.default.json.
{% endcomment %}

<section class="section-shell scheme-light text-dark not-found">
  <div class="page-width">
    <div class="not-found__content">
      <p class="not-found__brand">{{ settings.brand_display_name | upcase }}</p>
      <h1 class="not-found__heading">{{ 'page_404.heading' | t }}</h1>
      <div class="not-found__divider" aria-hidden="true"></div>
      <p class="not-found__subheading">{{ 'page_404.subheading' | t }}</p>
      <a class="button button--outline-gold" href="{{ routes.root_url }}">{{ 'page_404.button_label' | t }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main 404",
  "settings": []
}
{% endschema %}

