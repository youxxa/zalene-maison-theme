{% comment %}
  filename: sections/main-cart.liquid
  purpose: Full cart page fallback with editable quantities, order note, discount helper, and subtotal summary.
  key variables: cart, cart.items, settings.free_shipping_threshold
  ai_agent_edit_guide: Edit cart page layout or summary structure here. Keep item-level markup in the shared cart-drawer-item snippet when possible.
{% endcomment %}
<section class="section-shell scheme-light text-dark section-spacing--top-space-lg section-spacing--bottom-space-xl">
  <div class="page-width">
    {% render 'section-intro',
      eyebrow: settings.brand_display_name,
      heading: 'cart.heading' | t,
      subheading: 'cart.free_shipping_progress' | t: threshold: settings.free_shipping_threshold
    %}

    {% if cart.item_count > 0 %}
      <div class="collection-layout">
        <form class="collection-layout__main" action="{{ routes.cart_url }}" method="post">
          <div class="cart-drawer">
            {% for item in cart.items %}
              <div class="cart-item">
                <a href="{{ item.url }}" class="cart-item__media">
                  {% if item.image != blank %}
                    {{
                      item.image
                      | image_url: width: 180
                      | image_tag:
                        widths: '90, 140, 180',
                        width: 90,
                        loading: 'lazy',
                        class: 'product-card__image',
                        alt: item.title
                    }}
                  {% endif %}
                </a>
                <div class="cart-item__content">
                  <p class="product-card__title"><a href="{{ item.url }}">{{ item.product.title }}</a></p>
                  {% unless item.variant.title == 'Default Title' %}
                    <p>{{ item.variant.title }}</p>
                  {% endunless %}
                  <label for="Quantity-{{ item.index }}">{{ 'accessibility.quantity' | t }}</label>
                  <input class="form-field" id="Quantity-{{ item.index }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                  <p>{{ item.final_line_price | money }}</p>
                  <a class="text-link" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
                </div>
              </div>
            {% endfor %}
          </div>
          <button class="button button--secondary" type="submit" name="update">{{ 'cart.update' | t }}</button>
        </form>

        <div class="cart-page__summary">
          <form class="cart-summary-form" data-cart-note-form>
            <label for="CartPageNote">{{ 'cart.note' | t }}</label>
            <input class="form-field" id="CartPageNote" type="text" name="note" value="{{ cart.note }}" placeholder="{{ 'cart.note_placeholder' | t }}">
            <button class="button button--secondary" type="submit">{{ 'general.save' | t }}</button>
          </form>

          <form class="cart-summary-form" data-discount-form>
            <label for="CartPageDiscount">{{ 'cart.discount' | t }}</label>
            <input class="form-field" id="CartPageDiscount" type="text" name="discount" placeholder="{{ 'cart.discount_placeholder' | t }}">
            <button class="button button--secondary" type="submit">{{ 'cart.discount_apply' | t }}</button>
          </form>

          {% render 'trust-badges' %}

          <div class="price">
            <span>{{ 'cart.subtotal' | t }}</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <a class="button button--primary" href="{{ routes.checkout_url }}">{{ 'general.checkout' | t }}</a>
        </div>
      </div>
    {% else %}
      <div class="empty-state">
        <p>{{ 'cart.empty' | t }}</p>
        <a class="button button--secondary" href="{{ routes.all_products_collection_url }}">{{ 'general.continue_shopping' | t }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
