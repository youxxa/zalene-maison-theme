{% comment %}
  filename: layout/theme.liquid
  purpose: Primary document shell for every storefront page, including global assets, design tokens, accessibility helpers, and persistent sections.
  key variables: settings.*, request.page_type, content_for_header, content_for_layout, cart.item_count
  ai_agent_edit_guide: Edit global asset loading, root CSS variables, document metadata, or persistent section placement here. Keep page-specific UI in sections/snippets.
{% endcomment %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {% if settings.google_fonts_url != blank %}
      <link rel="stylesheet" href="{{ settings.google_fonts_url }}">
    {% endif %}
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <title>
      {{ page_title }}
      {% if current_tags %}
        {% assign meta_tags = current_tags | join: ', ' %}
        - {{ meta_tags }}
      {% endif %}
      {% if current_page != 1 %}
        - {{ 'general.page' | t: number: current_page }}
      {% endif %}
      {% unless page_title contains shop.name %}
        - {{ shop.name }}
      {% endunless %}
    </title>
    <style>
      :root {
        --color-primary-dark: #2C2C2C;
        --color-primary-accent: #D4AF37;
        --color-primary-light: #FFFFFF;
        --color-background-dark: #101010;
        --color-background-mid: #141414;
        --color-gold-overlay: rgba(212, 175, 55, 0.15);
        --color-text-primary: #1A1A1A;
        --color-announcement-background: #000000;
        --color-announcement-text: #D4AF37;
        --font-heading: 'Playfair Display', serif;
        --font-body: 'Cinzel', serif;
        --button-radius: 0px;
        --logo-width: {{ settings.logo_width }}px;
        --space-1: 16px;
        --space-2: 32px;
        --space-3: 48px;
        --space-4: 64px;
        --space-5: 96px;
        --space-6: 128px;
        --border-thin: 0.75px;
        --border-medium: 1.5px;
        --header-height: 76px;
        --container-width: 1440px;
        --copy-max-width: 720px;
        --transition-slow: 320ms ease;
        --transition-medium: 600ms cubic-bezier(0.16, 1, 0.3, 1);
        --transition-duration: 400ms cubic-bezier(0.16, 1, 0.3, 1);
        --transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--color-primary-light);
        color: var(--color-text-primary);
      }

      .theme-shell {
        min-height: 100vh;
      }

      .visually-hidden {
        position: absolute;
        inline-size: 1px;
        block-size: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
      }

      .skip-link {
        position: absolute;
        top: -999px;
        left: 0;
        z-index: 50;
        padding: var(--space-2);
        background: var(--color-primary-accent);
        color: var(--color-primary-dark);
        text-decoration: none;
      }

      .skip-link:focus {
        top: var(--space-2);
        left: var(--space-2);
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
      window.themeStrings = {
        addedToCart: {{ 'product.added_to_cart' | t | json }},
        freeShippingProgress: {{ 'cart.free_shipping_progress' | t: threshold: settings.free_shipping_threshold | json }},
        loading: {{ 'general.loading' | t | json }},
        emptyCart: {{ 'cart.empty' | t | json }},
        searchEmpty: {{ 'header.search_empty' | t | json }}
      };
    </script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}
  </head>
  <body class="template-{{ request.page_type | handle }}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>
    <div class="theme-shell">
      {% section 'header' %}
      {% section 'cart-drawer' %}
      <main id="MainContent" class="main-content" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>
      {% section 'footer' %}
      {% render 'cookie-banner' %}
    </div>
    <script>
      // Global fade-in micro-interaction
      document.addEventListener("DOMContentLoaded", () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };
        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        // Target all section-intro elements, images, and major blocks for the fade-in effect
        document.querySelectorAll('.section-intro, .rich-copy, .mega-menu, .image-text-section__media, .footer-nav').forEach((el) => {
          el.classList.add('fade-in-on-scroll');
          observer.observe(el);
        });
      });
    </script>
    <style>
      .floating-contact-btn {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: var(--font-body);
        font-size: 0.75rem;
        letter-spacing: 0.45rem;
        text-transform: uppercase;
        color: var(--color-primary-dark);
        background: transparent;
        text-decoration: none;
        display: flex;
        align-items: center;
        transition: color var(--transition-medium);
      }
      .floating-contact-btn::after {
        content: "";
        position: absolute;
        inset-inline: 0;
        inset-block-end: -6px;
        transform: scaleX(0);
        transform-origin: left;
        height: 0.75px;
        background: var(--color-primary-accent);
        transition: transform var(--transition-medium);
      }
      .floating-contact-btn:hover {
        color: var(--color-primary-accent);
      }
      .floating-contact-btn:hover::after {
        transform: scaleX(1);
      }
    </style>
    <a href="/pages/contact" class="floating-contact-btn">CONTACT US</a>
  </body>
</html>
