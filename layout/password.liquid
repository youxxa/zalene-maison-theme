{% comment %}
  filename: layout/password.liquid
  purpose: Minimal password page shell that preserves brand typography, spacing, and newsletter-ready prelaunch presentation.
  key variables: shop.password_message, shop.name, settings.*, content_for_layout
  ai_agent_edit_guide: Edit password page metadata, global styles, or shell structure here. Keep the actual page content within this layout or a future password section.
{% endcomment %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ 'password.heading' | t }} - {{ shop.name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {% if settings.google_fonts_url != blank %}
      <link rel="stylesheet" href="{{ settings.google_fonts_url }}">
    {% endif %}
    <style>
      :root {
        --color-primary-dark: {{ settings.color_primary | default: '#2C2C2C' }};
        --color-primary-accent: {{ settings.color_accent | default: '#D4AF37' }};
        --color-primary-light: {{ settings.color_background | default: '#FFFFFF' }};
        --font-heading: {{ settings.heading_font_family | default: "'Playfair Display', serif" }};
        --font-body: {{ settings.body_font_family | default: "'Cinzel', serif" }};
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px;
        background:
          linear-gradient(180deg, rgba(212, 175, 55, 0.08), transparent 40%),
          var(--color-primary-light);
        color: var(--color-primary-dark);
        font-family: var(--font-body);
      }

      .password-template {
        width: min(100%, 520px);
        padding: 40px 32px;
        border: 1px solid rgba(212, 175, 55, 0.4);
        text-align: center;
      }

      .password-template__brand {
        margin: 0 0 16px;
        font-family: var(--font-body);
        font-size: 0.875rem;
        letter-spacing: 0.5rem;
        text-transform: uppercase;
      }

      .password-template__heading {
        margin: 0 0 16px;
        font-family: var(--font-heading);
        font-size: clamp(2rem, 7vw, 3.75rem);
        font-style: italic;
        font-weight: 400;
      }

      .password-template__copy {
        margin: 0;
        font-size: 1rem;
        line-height: 1.8;
      }
    </style>
    {{ content_for_header }}
  </head>
  <body>
    <section class="password-template">
      <p class="password-template__brand">{{ settings.brand_display_name | default: 'Zalène Maison' }}</p>
      <h1 class="password-template__heading">{{ 'password.heading' | t }}</h1>
      <p class="password-template__copy">
        {% if shop.password_message != blank %}
          {{ shop.password_message }}
        {% else %}
          {{ 'password.subheading' | t }}
        {% endif %}
      </p>
      {{ content_for_layout }}
    </section>
  </body>
</html>
