{% comment %}
  filename: snippets/cookie-banner.liquid
  purpose: Minimal cookie consent banner (no inline CSS/JS) aligned with the Zalène Maison design system.
  key variables: locales cookie_banner.*, localStorage key managed in assets/theme.js
  ai_agent_edit_guide: Edit structure only. Move copy to locales and styling to assets/base.css. Behavioral changes belong in assets/theme.js.
{% endcomment %}

<div class="cookie-banner" id="CookieBanner" role="dialog" aria-live="polite" aria-label="{{ 'cookie_banner.aria_label' | t }}" hidden>
  <p class="cookie-banner__copy">{{ 'cookie_banner.message' | t }}</p>
  <div class="cookie-banner__actions">
    <button class="button button--secondary cookie-banner__button" type="button" data-cookie-decline>
      {{ 'cookie_banner.decline' | t }}
    </button>
    <button class="button button--primary cookie-banner__button" type="button" data-cookie-accept>
      {{ 'cookie_banner.accept' | t }}
    </button>
  </div>
</div>

