{% comment %}
  filename: snippets/cart-drawer-item.liquid
  purpose: Renders a single cart line item for the drawer and full cart page.
  key variables: item
  ai_agent_edit_guide: Edit line item structure, metadata, and remove link presentation here. Keep cart totals and surrounding layout outside this snippet.
{% endcomment %}
<article class="cart-item">
  <a href="{{ item.url }}" class="cart-item__media">
    {% if item.image != blank %}
      {{
        item.image
        | image_url: width: 180
        | image_tag:
          widths: '90, 140, 180',
          width: 90,
          loading: 'lazy',
          class: 'product-card__image',
          alt: item.title
      }}
    {% endif %}
  </a>
  <div class="cart-item__content">
    <p class="product-card__title"><a href="{{ item.url }}">{{ item.product.title }}</a></p>
    {% unless item.variant.title == 'Default Title' %}
      <p>{{ item.variant.title }}</p>
    {% endunless %}
    <p>{{ item.final_line_price | money }}</p>
    <p>{{ 'accessibility.quantity' | t }}: {{ item.quantity }}</p>
    <a class="text-link" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
  </div>
</article>
