{% comment %}
  filename: snippets/trust-badges.liquid
  purpose: Reusable trust badge list for product and cart contexts.
  key variables: settings.free_shipping_threshold
  ai_agent_edit_guide: Edit badge composition or icon treatment here if trust messaging changes globally.
{% endcomment %}
<div class="trust-badges">
  <div class="trust-badges__item">
    <svg class="trust-badges__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
    <span>{{ 'product.trust_shipping' | t: threshold: settings.free_shipping_threshold }}</span>
  </div>
  <div class="trust-badges__item">
    <svg class="trust-badges__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
    <span>{{ 'product.trust_returns' | t }}</span>
  </div>
  <div class="trust-badges__item">
    <svg class="trust-badges__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
    <span>{{ 'product.trust_payment' | t }}</span>
  </div>
</div>
